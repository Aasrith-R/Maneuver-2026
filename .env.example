# The Blue Alliance API Key
# Get your key at: https://www.thebluealliance.com/account
# Preferred (server-side / Netlify Functions). This does NOT get exposed to the browser.
TBA_API_KEY=your_tba_api_key_here

# Optional (client-side / Vite). Anything prefixed with `VITE_` is exposed to the browser bundle.
# Only use this for local dev if you understand the tradeoff.
VITE_TBA_API_KEY=your_tba_api_key_here


# Nexus Stats API Key
# Get your key at: https://frc.nexus/
# Preferred (server-side / Netlify Functions). This does NOT get exposed to the browser.
NEXUS_API_KEY=your_nexus_api_key_here

# Optional (client-side / Vite). Anything prefixed with `VITE_` is exposed to the browser bundle.
# Only use this for local dev if you understand the tradeoff.
VITE_NEXUS_API_KEY=your_nexus_api_key_here
